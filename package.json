{
  "name": "game2048",
  "private": true,
  "license": "MIT",
  "version": "1.1.1",
  "author": "Dmitriy Shalberkin",
  "repository": {
    "type": "git",
    "url": "https://github.com/git-dmitriy/game2048.git"
  },
  "bugs": "https://github.com/git-dmitriy/game2048/issues",
  "homepage": "https://github.com/git-dmitriy/game2048#readme",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "build:gh-pages": "GITHUB_PAGES=true npm run build",
    "preview": "vite preview",
    "preview:gh-pages": "GITHUB_PAGES=true vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "generate:pwa-assets": "node scripts/generate-pwa-assets.mjs",
    "generate:sounds": "node scripts/generate-sounds.mjs",
    "prebuild": "npm run generate:pwa-assets && npm run generate:sounds",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "vue": "^3.4.0",
    "vue-i18n": "^11.4.5"
  },
  "devDependencies": {
    "@iconify-icons/mdi": "^1.2.48",
    "@iconify-icons/simple-icons": "^1.2.74",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "sharp": "^0.34.2",
    "standard-version": "^9.5.0",
    "typescript": "^6.0.3",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^2.2.10"
  }
}
